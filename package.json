{
  "name": "@figliolia/react-galena",
  "version": "5.0.1",
  "description": "React Bindings for the Galena state management library",
  "keywords": [
    "@figliolia/galena",
    "flux",
    "react",
    "state",
    "state management"
  ],
  "homepage": "https://github.com/alexfigliolia/react-galena#readme",
  "license": "MIT",
  "author": "Alex Figliolia",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexfigliolia/react-galena.git"
  },
  "files": [
    "dist",
    "src",
    "media"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint --type-aware --type-check --report-unused-disable-directives --fix && oxfmt"
  },
  "devDependencies": {
    "@figliolia/galena": "^4.0.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.36.0",
    "oxlint-tsgolint": "^0.18.0",
    "react": "^19.2.4",
    "tsdown": "^0.21.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@figliolia/galena": ">=4.0.0",
    "react": ">=18.0.0"
  }
}
